<Window x:Class="TorrentDuplicationChecker.Views.HelpLegendWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:TorrentDuplicationChecker.Localization"
        Title="{x:Static loc:Strings.Help_WindowTitle}"
        Width="460"
        MinHeight="260"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource Brush.Bg}">
    <DockPanel Margin="22,18,22,18">
        <Border DockPanel.Dock="Bottom"
                Padding="0,16,0,0"
                Margin="0,4,0,0">
            <Button HorizontalAlignment="Right"
                    MinWidth="100"
                    IsDefault="True"
                    Style="{StaticResource UiButtonPrimary}"
                    Content="{x:Static loc:Strings.Btn_Ok}"
                    Click="Ok_OnClick"/>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="360">
            <StackPanel>
                <TextBlock Text="{x:Static loc:Strings.Help_LegendTitle}"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}"
                           Margin="0,0,0,10"/>
                <TextBlock Text="{x:Static loc:Strings.Help_LegendIntro}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource Brush.TextMuted}"
                           LineHeight="20"
                           Margin="0,0,0,16"/>

                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <Border DockPanel.Dock="Left"
                                Width="20"
                                Height="20"
                                CornerRadius="4"
                                Margin="0,2,12,0"
                                Background="{StaticResource Brush.RecencyNewest}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"/>
                        <TextBlock Text="{x:Static loc:Strings.Help_LegendGreen}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,10">
                        <Border DockPanel.Dock="Left"
                                Width="20"
                                Height="20"
                                CornerRadius="4"
                                Margin="0,2,12,0"
                                Background="{StaticResource Brush.RecencyOlder}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"/>
                        <TextBlock Text="{x:Static loc:Strings.Help_LegendAmber}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,10">
                        <Border DockPanel.Dock="Left"
                                Width="20"
                                Height="20"
                                CornerRadius="4"
                                Margin="0,2,12,0"
                                Background="{StaticResource Brush.RecencyConflict}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"/>
                        <TextBlock Text="{x:Static loc:Strings.Help_LegendRed}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
