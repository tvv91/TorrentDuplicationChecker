<Window x:Class="TorrentDuplicationChecker.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:TorrentDuplicationChecker.Localization"
        Title="{x:Static loc:Strings.Settings_WindowTitle}"
        Height="460"
        Width="640"
        WindowStartupLocation="CenterOwner"
        MinHeight="400"
        MinWidth="520"
        Background="{StaticResource Brush.Bg}">
    <DockPanel Margin="24">
        <TextBlock DockPanel.Dock="Top"
                   Text="{x:Static loc:Strings.Settings_WindowTitle}"
                   Style="{StaticResource Label.DialogTitle}"/>

        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,1,0,0"
                Padding="0,16,0,0"
                Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{x:Static loc:Strings.Btn_Ok}"
                        Width="100"
                        Margin="0,0,10,0"
                        Style="{StaticResource UiButtonPrimary}"
                        IsDefault="True"
                        Click="Ok_OnClick"/>
                <Button Content="{x:Static loc:Strings.Btn_CancelDialog}"
                        Width="100"
                        Style="{StaticResource UiButtonToolbarSecondary}"
                        IsCancel="True"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,8,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{x:Static loc:Strings.Settings_UiLanguage}" Style="{StaticResource Label.Section}"/>
                <ComboBox Grid.Row="1"
                          Margin="0,0,0,16"
                          ItemsSource="{Binding LanguageOptions}"
                          SelectedValue="{Binding Settings.UiLanguage}"
                          SelectedValuePath="Code"
                          DisplayMemberPath="DisplayName"/>

                <TextBlock Grid.Row="2" Text="{x:Static loc:Strings.Settings_TorrentClientApi}" Style="{StaticResource Label.Section}"/>
                <ComboBox Grid.Row="3"
                          Margin="0,0,0,16"
                          ItemsSource="{Binding ClientOptions}"
                          SelectedValue="{Binding SelectedClientKindId}"
                          SelectedValuePath="Id"
                          DisplayMemberPath="DisplayName"/>

                <TextBlock Grid.Row="4" Text="{x:Static loc:Strings.Settings_WebUiAddress}" Style="{StaticResource Label.Section}"/>
                <TextBox Grid.Row="5"
                         Margin="0,0,0,16"
                         Text="{Binding Settings.WebUiBaseUrl, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="6" Text="{x:Static loc:Strings.Settings_AccountOptional}" Style="{StaticResource Label.Section}"/>
                <Grid Grid.Row="7" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static loc:Strings.Label_Login}" Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{x:Static loc:Strings.Label_Password}" Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,0,6"/>
                    <TextBox Grid.Row="1" Grid.Column="0"
                             Text="{Binding Settings.UserName, UpdateSourceTrigger=PropertyChanged}"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Grid.Row="1"
                                 Grid.Column="2"
                                 PasswordChanged="PasswordBox_OnPasswordChanged"/>
                </Grid>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
